# Konfigurasi Ollama Chat Assistant
# Copy file ini ke .env dan sesuaikan jika perlu

# URL Ollama API (default: localhost:11434)
OLLAMA_API_URL=http://localhost:11434

# Model default
DEFAULT_MODEL=gemma3:1b

# Parameter default
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=500

# Streamlit config
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0